# Vercel production environment variables (Project → Settings → Environment Variables)
# Use the SAME Supabase project as local dev for identical behaviour.
# Vite embeds VITE_* vars at build time — redeploy after changing them.

VITE_SUPABASE_URL_PROD=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY_PROD=your-anon-key
VITE_SUPABASE_STORAGE_BUCKET_PROD=Pics

# Optional fallbacks (if you only set _DEV locally, prod build still works):
# VITE_SUPABASE_URL_DEV=...
# VITE_SUPABASE_ANON_KEY_DEV=...
