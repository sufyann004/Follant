# Server
PORT=3000
NODE_ENV=development

# Public URL (OAuth callbacks, email links)
APP_URL="http://localhost:3000"

# Optional: Gemini (legacy AI Studio scaffold)
GEMINI_API_KEY=""

# ─── Supabase — development project (local / preview) ─────────────────────────
# Create a separate Supabase project for dev. Copy from Dashboard → Settings → API.
VITE_SUPABASE_URL_DEV=https://YOUR-DEV-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY_DEV=your-dev-anon-key

# Optional: use a non-public schema in a shared project (see supabase/environments.md)
# VITE_SUPABASE_SCHEMA_DEV=dev

# Storage bucket for avatars, logos, and banners (must match Supabase dashboard)
VITE_SUPABASE_STORAGE_BUCKET_DEV=Pics

# Server-only (Edge Functions / migrations CLI — never prefix with VITE_)
SUPABASE_URL_DEV=https://YOUR-DEV-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY_DEV=your-dev-service-role-key

# ─── Supabase — production project ───────────────────────────────────────────
# Used when Vite runs with --mode production (npm run build / preview).
VITE_SUPABASE_URL_PROD=https://YOUR-PROD-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY_PROD=your-prod-anon-key

# VITE_SUPABASE_SCHEMA_PROD=public
# VITE_SUPABASE_STORAGE_BUCKET_PROD=Pics

SUPABASE_URL_PROD=https://YOUR-PROD-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY_PROD=your-prod-service-role-key

# ─── Fallback (single-project setup) ─────────────────────────────────────────
# If mode-specific vars are omitted, these are used for any environment.
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
